# ============================================================
# IAM-CORE — Environment Configuration Example
# ============================================================
# This file contains REQUIRED configuration keys.
# Copy this file to:
#   .env        (for local development)
#   .env.test   (for integration tests)
#
# NEVER commit real secrets.
# ============================================================

# ============================================================
# Application Environment
# ============================================================

# Allowed:
#   production
#   staging
#   development
#   testing
APP_ENV=development

# Debug mode (true / false)
APP_DEBUG=true

# Application timezone (valid PHP timezone identifier)
APP_TIMEZONE=Africa/Cairo

# ============================================================
# Database (MySQL)
# ============================================================

# Database host
DB_HOST=127.0.0.1

# Database port
DB_PORT=3306

# Database name
DB_NAME=iam_core

# Database username
DB_USER=root

# Database password
# ⚠️ NEVER commit real passwords
DB_PASS=change_me

# ============================================================
# Blind Index / Lookup Secret (REQUIRED)
# ============================================================
#
# Used for:
# - Deterministic lookup hashing (HMAC-SHA256)
# - Unique identifier detection
#
# Requirements:
# - Minimum 32 characters
# - Cryptographically secure random string
#
EMAIL_BLIND_INDEX_KEY=replace_with_random_32_char_secret

# ============================================================
# Crypto Key Ring (REQUIRED)
# ============================================================
#
# Used for:
# - AES-256-GCM encryption
# - HKDF context derivation
# - Key rotation
#
# CRYPTO_KEYS must be a JSON array:
#   [{"id":"v1","key":"32_byte_secret"}]
#
# Key requirements:
# - Exactly 32 bytes (for AES-256-GCM)
# - Cryptographically secure random material
#
CRYPTO_ACTIVE_KEY_ID=v1

CRYPTO_KEYS='[{"id":"v1","key":"replace_with_32_byte_secret_here"}]'

# ============================================================
# Password Pepper Ring (REQUIRED)
# ============================================================

# Used for:
#   - Password hashing
#   - Pepper rotation
#
# PASSWORD_PEPPERS must be a JSON object map:
#   { "p1": "secret", "p2": "secret" }

# Active pepper ID
# MUST match a key in PASSWORD_PEPPERS
PASSWORD_ACTIVE_PEPPER_ID=p1

# Pepper secrets
# ⚠️ NOT passwords — random secrets only
PASSWORD_PEPPERS='{"p1":"GENERATE_SECURE_KEY_MIN_32_CHARS"}'

# ============================================================
# Password Hashing — Argon2id (OPTIONAL)
# ============================================================

# Controls password hashing cost parameters
# If omitted, defaults are applied internally
#
# Changing these values:
#   - DOES NOT break existing passwords
#   - Triggers automatic re-hash on next login
#
# Example values are production-safe defaults
PASSWORD_ARGON2_OPTIONS='{"memory_cost":65536,"time_cost":4,"threads":1}'

# ============================================================
# Notes
# ============================================================
#
# 1) CRYPTO_KEYS must contain the active key ID.
# 2) EMAIL_BLIND_INDEX_KEY must NOT be empty.
# 3) Missing required variables MUST cause fail-fast behavior.
# 4) Do NOT use weak secrets in production.
#
# ============================================================

IAM_TRUSTED_IPS=127.0.0.1,10.0.0.1,192.168.1.0/24

# ============================================================
# Logging Configuration (PSR-3)
# ============================================================

# Base path for application logs
# Relative paths are resolved from project root
LOG_PATH=storage/logs

# Log retention period (days)
# Old logs beyond this period may be cleaned
LOG_RETENTION_DAYS=14

# Timezone used for log timestamps
# Must be a valid PHP timezone identifier
LOG_TIMEZONE=Africa/Cairo