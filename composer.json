{
  "name": "maatify/iam-core",
  "description": "Maatify IAM v1 - Multi-tenant Identity Provider (Secure-by-Design)",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-sodium": "*",
    "ext-zlib": "*",
    "firebase/php-jwt": "^7.0",

    "maatify/crypto": "^1.0",
    "maatify/exceptions": "^1.1",
    "maatify/psr-logger": "^1.0",
    "maatify/shared-common": "^1.0",
    "maatify/validation": "^1.0",

    "middlewares/trailing-slash": "^2.1",
    "php-di/php-di": "^7.1",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "ramsey/uuid": "^4.9",
    "respect/validation": "^2.4",
    "slim/psr7": "^1.8",
    "slim/slim": "^4.15",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\Iam\\": "src/",
      "Maatify\\EmailDelivery\\": "Modules/EmailDelivery"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level=max",
    "format": "php-cs-fixer fix"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
